{
  "title": "Podio",
  "description": "Podio Project Management and Collaboration Software",
  "buildType": "docker",
  "envVars": {
    "PODIO_APP_ID": {
      "required": true,
      "description": "Podio OAuth Application ID"
    },
    "PODIO_APP_SECRET": {
      "required": true,
      "description": "Podio OAuth Application Secret"
    }
  },
  "credentials": {
    "fields": {
      "oauth": {
        "label": "Authentication",
        "viewClass": "OAuthFieldView",
        "required": true
      }
    },
    "oauth2": {
      "client_id": "{{PODIO_APP_ID}}",
      "client_secret": "{{PODIO_APP_SECRET}}",
      "email": "{{email}}",
      "apiKey": "{{apiKey}}",
      "auth_uri": "https://podio.com/oauth/authorize",
      "token_uri": "https://podio.com/oauth/token"
    }
  },
  "actions": {
    "activateApp": {
      "main": "./lib/actions/apps/activateApp.js",
      "title": "App: Activate",
      "description": "Re-activate a previously deactivated app",
      "metadata": {
        "in": "./lib/schemas/apps/activateApp.in.json"
      }
    },
    "addAppField": {
      "main": "./lib/actions/apps/addAppField.js",
      "title": "App: Add Field",
      "description": "Add a new field to an existing app",
      "metadata": {
        "in": "./lib/schemas/apps/addAppField.in.json"
      }
    },
    "createApp": {
      "main": "./lib/actions/apps/createApp.js",
      "title": "App: Create",
      "description": "Create a new app in a space",
      "fields": {
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        }
      },
      "metadata": {
        "in": "./lib/schemas/apps/createApp.in.json"
      }
    },
    "deactivateApp": {
      "main": "./lib/actions/apps/deactivateApp.js",
      "title": "App: Deactivate",
      "description": "Deactivate an app (hides it without deleting)",
      "metadata": {
        "in": "./lib/schemas/apps/deactivateApp.in.json"
      }
    },
    "deleteApp": {
      "main": "./lib/actions/apps/deleteApp.js",
      "title": "App: Delete",
      "description": "Permanently delete an app and all its items",
      "metadata": {
        "in": "./lib/schemas/apps/deleteApp.in.json"
      }
    },
    "deleteAppField": {
      "main": "./lib/actions/apps/deleteAppField.js",
      "title": "App: Delete Field",
      "description": "Permanently delete a field from an app",
      "metadata": {
        "in": "./lib/schemas/apps/deleteAppField.in.json"
      }
    },
    "getApp": {
      "main": "./lib/actions/apps/getApp.js",
      "title": "App: Get",
      "description": "Retrieve app details including configuration and fields",
      "metadata": {
        "in": "./lib/schemas/getApp.in.json"
      }
    },
    "getAllApp": {
      "main": "./lib/actions/apps/getAllApp.js",
      "title": "App: Get All Apps",
      "description": "Retrieve all apps accessible to the authenticated user",
      "metadata": {
        "in": "./lib/schemas/getAllApp.in.json"
      }
    },
    "getAppsBySpace": {
      "main": "./lib/actions/apps/getAppsBySpace.js",
      "title": "App: Get Apps by Space",
      "description": "List all apps in a specific space",
      "metadata": {
        "in": "./lib/schemas/apps/getAppsBySpace.in.json"
      }
    },
    "getAppByLabel": {
      "main": "./lib/actions/apps/getAppByLabel.js",
      "title": "App: Get by Labels",
      "description": "Retrieve app by organization, space, and app URL labels",
      "metadata": {
        "in": "./lib/schemas/apps/getAppByLabel.in.json"
      }
    },
    "getAppSpaceByUrlLabel": {
      "main": "./lib/actions/apps/getAppSpaceByUrlLabel.js",
      "title": "App: Get by Space URL Label",
      "description": "Retrieve app using the space ID and app URL label",
      "metadata": {
        "in": "./lib/schemas/apps/getAppSpaceByUrlLabel.in.json"
      }
    },
    "getAppDependencies": {
      "main": "./lib/actions/apps/getAppDependencies.js",
      "title": "App: Get Dependencies",
      "description": "Get apps that this app depends on (has reference fields to)",
      "metadata": {
        "in": "./lib/schemas/apps/getAppDependencies.in.json"
      }
    },
    "getFeatures": {
      "main": "./lib/actions/apps/getFeatures.js",
      "title": "App: Get Features",
      "description": "App features (filters, sortings). app_ids required; same space.",
      "metadata": {
        "in": "./lib/schemas/apps/getFeatures.in.json"
      }
    },
    "getAppField": {
      "main": "./lib/actions/apps/getAppField.js",
      "title": "App: Get Field",
      "description": "Retrieve configuration details for a specific app field",
      "metadata": {
        "in": "./lib/schemas/getAppField.in.json"
      }
    },
    "getSpaceAppDependencies": {
      "main": "./lib/actions/apps/getSpaceAppDependencies.js",
      "title": "App: Get Space App Dependencies",
      "description": "Get all app dependencies within a space",
      "metadata": {
        "in": "./lib/schemas/apps/getSpaceAppDependencies.in.json"
      }
    },
    "installApp": {
      "main": "./lib/actions/apps/install.js",
      "title": "App: Install from Share",
      "description": "Install an app from the App Market into a space",
      "metadata": {
        "in": "./lib/schemas/installApp.in.json"
      }
    },
    "updateApp": {
      "main": "./lib/actions/apps/updateApp.js",
      "title": "App: Update",
      "description": "Update app config (name, description, settings)",
      "metadata": {
        "in": "./lib/schemas/apps/updateApp.in.json"
      }
    },
    "updateAppField": {
      "main": "./lib/actions/apps/updateAppField.js",
      "title": "App: Update Field",
      "description": "Update configuration for an app field",
      "metadata": {
        "in": "./lib/schemas/updateAppField.in.json"
      },
      "dynamicMetadata": true
    },
    "addComment": {
      "main": "./lib/actions/comments/addComment.js",
      "title": "Comment: Add",
      "description": "Add a comment to an item, task, or other object",
      "fields": {
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        }
      },
      "metadata": {
        "in": "./lib/schemas/addComment.in.json"
      }
    },
    "deleteComment": {
      "main": "./lib/actions/comments/deleteComment.js",
      "title": "Comment: Delete",
      "description": "Delete a comment",
      "metadata": {
        "in": "./lib/schemas/getComment.in.json"
      }
    },
    "getComment": {
      "main": "./lib/actions/comments/getComment.js",
      "title": "Comment: Get",
      "description": "Retrieve a specific comment by ID",
      "metadata": {
        "in": "./lib/schemas/getComment.in.json"
      }
    },
    "getCommentObject": {
      "main": "./lib/actions/comments/getCommentObject.js",
      "title": "Comment: Get by Object",
      "description": "List comments on an object",
      "metadata": {
        "in": "./lib/schemas/getCommentObject.in.json"
      }
    },
    "getCommentRevision": {
      "main": "./lib/actions/comments/getCommentRevision.js",
      "title": "Comment: Get Revision",
      "description": "Retrieve a specific revision of a comment",
      "metadata": {
        "in": "./lib/schemas/getComment.in.json"
      }
    },
    "updateComment": {
      "main": "./lib/actions/comments/updateComment.js",
      "title": "Comment: Update",
      "description": "Update an existing comment",
      "fields": {
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        }
      },
      "metadata": {
        "in": "./lib/schemas/updateComment.in.json"
      }
    },
    "getTokens": {
      "main": "./lib/actions/all/getTokens.js",
      "title": "Credential: Get Tokens",
      "description": "Retrieve current OAuth tokens for debugging or external use",
      "fields": {
        "random_id": {
          "viewClass": "TextFieldView",
          "prompt": "Enter any value",
          "label": "Trigger Value",
          "required": true
        }
      }
    },
    "showCredential": {
      "main": "./lib/actions/all/showCredential.js",
      "title": "Credential: Show",
      "description": "Display current credential information for debugging"
    },
    "addEmbed": {
      "main": "./lib/actions/embeds/addEmbed.js",
      "title": "Embed: Add",
      "description": "Fetch URL metadata to create an embed",
      "metadata": {
        "in": "./lib/schemas/embeds/addEmbed.in.json"
      }
    },
    "attachFile": {
      "main": "./lib/actions/files/attachFile.js",
      "title": "File: Attach File",
      "description": "Attach an uploaded file to a Podio object",
      "fields": {
        "ref_type": {
          "viewClass": "SelectView",
          "label": "Object Type",
          "required": true,
          "model": {
            "item": "Item",
            "task": "Task",
            "status": "Status Update",
            "comment": "Comment",
            "space": "Space"
          },
          "prompt": "Select object type"
        }
      },
      "metadata": {
        "in": "./lib/schemas/attachFile.in.json"
      }
    },
    "copyFile": {
      "main": "./lib/actions/files/copyFile.js",
      "title": "File: Copy",
      "description": "Create a copy of an existing file",
      "metadata": {
        "in": "./lib/schemas/copyFile.in.json"
      }
    },
    "getActualFile": {
      "main": "./lib/actions/files/getActualFile.js",
      "title": "File: Download",
      "description": "Get the actual file content (binary data or URL)",
      "metadata": {
        "in": "./lib/schemas/getActualFile.in.json"
      }
    },
    "getFile": {
      "main": "./lib/actions/files/getFile.js",
      "title": "File: Get",
      "description": "Retrieve file metadata by ID",
      "metadata": {
        "in": "./lib/schemas/getFile.in.json"
      }
    },
    "getFilesbyApp": {
      "main": "./lib/actions/files/getFilesbyApp.js",
      "title": "File: Get All by App",
      "description": "Retrieve all files attached to items in an app",
      "metadata": {
        "in": "./lib/schemas/getFilesbyApp.in.json"
      }
    },
    "publicUrl": {
      "main": "./lib/actions/files/uploadFileV3.js",
      "title": "File: Upload from Base64",
      "description": "Upload a file to Podio from Base64-encoded data",
      "metadata": {
        "in": "./lib/schemas/uploadFilev3.in.json"
      }
    },
    "UploadFile": {
      "main": "./lib/actions/files/uploadFileV2.js",
      "title": "File: Upload from URL",
      "description": "Upload a file to Podio from a URL",
      "metadata": {
        "in": "./lib/schemas/uploadFile.in.json"
      }
    },
    "uploadFile": {
      "main": "./lib/actions/files/uploadFile.js",
      "title": "File: Upload V2",
      "description": "Upload a file to Podio (legacy version)",
      "metadata": {
        "in": "./lib/schemas/uploadFileV2.in.json"
      }
    },
    "createHooks": {
      "main": "./lib/actions/hooks/createHooks.js",
      "title": "Hook: Create",
      "description": "Create Podio webhooks. Set appId for calc-field guard (calc fields never fire).",
      "fields": {
        "hookType": {
          "viewClass": "SelectView",
          "prompt": "Select a hook type",
          "label": "Hook Type",
          "model": {
            "space": "Space",
            "app": "App",
            "field": "Field (item.update only; not calc fields)"
          },
          "required": true
        },
        "hook_type": {
          "viewClass": "MultiSelectView",
          "label": "Events",
          "model": "getHooks",
          "required": true,
          "note": "For Hook Type = Field, only item.update is supported."
        },
        "appId": {
          "viewClass": "TextFieldView",
          "label": "App ID (optional, enables calc-field guard)",
          "required": false,
          "note": "For Field hooks, set the parent app_id to refuse calculation fields."
        }
      },
      "metadata": {
        "in": "./lib/schemas/createHooks.in.json"
      }
    },
    "deleteHooks": {
      "main": "./lib/actions/hooks/deleteHooks.js",
      "title": "Hook: Delete",
      "description": "Remove a webhook",
      "metadata": {
        "in": "./lib/schemas/deleteHooks.in.json"
      }
    },
    "getHooks": {
      "main": "./lib/actions/hooks/getHooks.js",
      "title": "Hook: Get",
      "description": "Retrieve webhooks configured for an object",
      "metadata": {
        "in": "./lib/schemas/createHooks.in.json"
      }
    },
    "verifyHooks": {
      "main": "./lib/actions/hooks/verifyHooks.js",
      "title": "Hook: Verify",
      "description": "Manually verify a webhook (useful after creation)",
      "metadata": {
        "in": "./lib/schemas/verifyHooks.in.json"
      }
    },
    "cloneItem": {
      "main": "./lib/actions/items/cloneItem.js",
      "title": "Item: Clone",
      "description": "Create a copy of an existing item",
      "metadata": {
        "in": "./lib/schemas/cloneItem.in.json"
      }
    },
    "createItem": {
      "main": "./lib/actions/items/createItem.js",
      "title": "Item: Create",
      "description": "Create item (schema-based field mapping; static app_id)",
      "fields": {
        "appId": {
          "viewClass": "TextFieldView",
          "prompt": "Enter app_id",
          "label": "Podio Application",
          "required": true
        },
        "hook": {
          "label": "Execute Hooks",
          "viewClass": "CheckBoxView"
        },
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        },
        "autoAddCategoryOptions": {
          "label": "Auto-Add Missing Category Options",
          "viewClass": "CheckBoxView"
        }
      },
      "dynamicMetadata": true
    },
    "createItemDynamic": {
      "main": "./lib/actions/items/createItemDynamic.js",
      "title": "Item: Create (Dynamic)",
      "description": "Create item — dynamic app_id, raw JSON payload (advanced).",
      "fields": {
        "hook": {
          "label": "Execute Hooks",
          "viewClass": "CheckBoxView"
        },
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        },
        "autoAddCategoryOptions": {
          "label": "Auto-Add Missing Category Options",
          "viewClass": "CheckBoxView"
        }
      },
      "metadata": {
        "in": "./lib/schemas/items/createItemDynamic.in.json"
      }
    },
    "createItemIdempotent": {
      "main": "./lib/actions/items/createItemIdempotent.js",
      "title": "Item: Create (Idempotent by external_id)",
      "description": "Retry-safe create by external_id. Pair with reconcileBatch for batch reliability.",
      "fields": {
        "appId": {
          "viewClass": "TextFieldView",
          "prompt": "Enter app_id",
          "label": "Podio Application",
          "required": true
        },
        "hook": {
          "label": "Execute Hooks",
          "viewClass": "CheckBoxView"
        },
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        }
      },
      "metadata": {
        "in": "./lib/schemas/items/createItemIdempotent.in.json"
      }
    },
    "deleteItem": {
      "main": "./lib/actions/items/deleteItem.js",
      "title": "Item: Delete",
      "description": "Permanently delete an item",
      "metadata": {
        "in": "./lib/schemas/deleteItem.in.json"
      }
    },
    "filterItems": {
      "main": "./lib/actions/all/filterItems.js",
      "title": "Item: Filter",
      "description": "Filter items in an app (auto-paginated)",
      "metadata": {
        "in": "./lib/schemas/filterItems.in.json"
      }
    },
    "filterItemsByView": {
      "main": "./lib/actions/items/filterItembyView.js",
      "title": "Item: Filter by View",
      "description": "Filter items using a saved view's criteria",
      "metadata": {
        "in": "./lib/schemas/filterItembyView.in.json"
      }
    },
    "findReferencesItems": {
      "main": "./lib/actions/items/findReferencesItems.js",
      "title": "Item: Find Referenceable",
      "description": "Search for items that can be referenced by a field",
      "metadata": {
        "in": "./lib/schemas/findReferencesItems.in.json"
      }
    },
    "getItem": {
      "main": "./lib/actions/items/getItem.js",
      "title": "Item: Get",
      "description": "Retrieve a single item by ID with all field values",
      "metadata": {
        "in": "./lib/schemas/getItem.in.json"
      }
    },
    "getItemsbyApp": {
      "main": "./lib/actions/items/getItemsbyApp.js",
      "title": "Item: Get All by App",
      "description": "Retrieve all items in an app",
      "metadata": {
        "in": "./lib/schemas/getItemsbyApp.in.json"
      }
    },
    "getItemCount": {
      "main": "./lib/actions/items/getItemCount.js",
      "title": "Item: Get Count",
      "description": "Get the total number of items in an app",
      "metadata": {
        "in": "./lib/schemas/getItemCount.in.json"
      }
    },
    "getItemFieldValueV2": {
      "main": "./lib/actions/items/getItemFieldValueV2.js",
      "title": "Item: Get Field Value (v2)",
      "description": "Retrieve values for a specific field on an item (V2 format)",
      "metadata": {
        "in": "./lib/schemas/items/getItemFieldValueV2.in.json"
      }
    },
    "getItemReferences": {
      "main": "./lib/actions/items/getItemReferences.js",
      "title": "Item: Get References",
      "description": "Get items that reference this item",
      "metadata": {
        "in": "./lib/schemas/getItemReferences.in.json"
      }
    },
    "getReferencesToItemByField": {
      "main": "./lib/actions/items/getReferencesToItemByField.js",
      "title": "Item: Get References by Field",
      "description": "Get items referencing this item through a specific field",
      "metadata": {
        "in": "./lib/schemas/getReferencesToItemByField.in.json"
      }
    },
    "getItemRevisionDifference": {
      "main": "./lib/actions/items/getItemRevisionDifference.js",
      "title": "Item: Get Revision Difference",
      "description": "Compare two revisions of an item to see changes",
      "metadata": {
        "in": "./lib/schemas/getItemRevisionDifference.in.json"
      }
    },
    "getItemValue": {
      "main": "./lib/actions/items/getItemV2.js",
      "title": "Item: Get Values (v2)",
      "description": "Get item field values (V2 simplified format)",
      "metadata": {
        "in": "./lib/schemas/getItem.in.json"
      }
    },
    "reconcileBatch": {
      "main": "./lib/actions/items/reconcileBatch.js",
      "title": "Item: Reconcile Batch (by external_id)",
      "description": "Reconcile batch by external_id: {found, missing, errors}. Re-feed missing.",
      "fields": {
        "appId": {
          "viewClass": "TextFieldView",
          "prompt": "Enter app_id",
          "label": "Podio Application",
          "required": true
        },
        "concurrency": {
          "viewClass": "TextFieldView",
          "label": "Concurrency",
          "note": "Parallel lookups (default 4)."
        }
      },
      "metadata": {
        "in": "./lib/schemas/items/reconcileBatch.in.json"
      }
    },
    "updateItem": {
      "main": "./lib/actions/items/updateItem.js",
      "title": "Item: Update",
      "description": "Update an existing item using schema-based field mapper",
      "fields": {
        "appId": {
          "viewClass": "TextFieldView",
          "prompt": "Enter app_id",
          "label": "Podio Application",
          "required": true
        },
        "hook": {
          "label": "Execute Hooks",
          "viewClass": "CheckBoxView"
        },
        "silent": {
          "label": "Silent Mode",
          "viewClass": "CheckBoxView"
        },
        "autoAddCategoryOptions": {
          "label": "Auto-Add Missing Category Options",
          "viewClass": "CheckBoxView"
        }
      },
      "dynamicMetadata": true
    },
    "getAllSpacesOrg": {
      "main": "./lib/actions/organisations/getAllSpacesOrg.js",
      "title": "Org: Get All Spaces",
      "description": "List all spaces in an organization",
      "metadata": {
        "in": "./lib/schemas/getOrg.in.json"
      }
    },
    "getOrgUrl": {
      "main": "./lib/actions/organisations/getOrgUrl.js",
      "title": "Org: Get by URL",
      "description": "Retrieve organization details by URL slug",
      "metadata": {
        "in": "./lib/schemas/getOrgUrl.in.json"
      }
    },
    "getOrg": {
      "main": "./lib/actions/organisations/getOrg.js",
      "title": "Org: Get Organization",
      "description": "Retrieve details for a specific organization",
      "fields": {
        "orgId": {
          "viewClass": "SelectView",
          "prompt": "Select an Organisation",
          "label": "Podio Organisation",
          "required": true,
          "model": "organisations"
        }
      }
    },
    "searchApp": {
      "main": "./lib/actions/all/searchApp.js",
      "title": "Search: App",
      "description": "Search for items within a specific app",
      "dynamicMetadata": true,
      "metadata": {
        "in": "./lib/schemas/searchApp.in.json"
      }
    },
    "search": {
      "main": "./lib/actions/all/search.js",
      "title": "Search: Global",
      "description": "Global unscoped Podio search (v2 GET). Returns {counts, results}.",
      "fields": {
        "query": {
          "viewClass": "TextFieldView",
          "label": "Search Query",
          "placeholder": "Enter search terms...",
          "required": true
        },
        "ref_type": {
          "viewClass": "SelectView",
          "prompt": "Select content type to search",
          "label": "Content Type",
          "model": {
            "item": "Items",
            "task": "Tasks",
            "file": "Files",
            "conversation": "Conversations",
            "profile": "Profiles",
            "app": "Apps"
          }
        },
        "counts": {
          "viewClass": "CheckBoxView",
          "label": "Include Counts"
        },
        "highlights": {
          "viewClass": "CheckBoxView",
          "label": "Include Highlights"
        },
        "limit": {
          "viewClass": "TextFieldView",
          "label": "Limit",
          "placeholder": "20"
        },
        "offset": {
          "viewClass": "TextFieldView",
          "label": "Offset",
          "placeholder": "0"
        }
      }
    },
    "searchOrg": {
      "main": "./lib/actions/all/searchOrg.js",
      "title": "Search: Organization (v1)",
      "description": "Search within an org (v1, bare array). See searchOrgV2 for facet counts.",
      "fields": {
        "orgId": {
          "viewClass": "SelectView",
          "prompt": "Select an Organisation",
          "label": "Podio Organisation",
          "required": true,
          "model": "organisations"
        }
      },
      "dynamicMetadata": true
    },
    "searchOrgV2": {
      "main": "./lib/actions/all/searchOrgV2.js",
      "title": "Search: Organization (v2 with counts)",
      "description": "Search within an org (v2, {counts, results}). counts=true populates aggregates.",
      "fields": {
        "orgId": {
          "viewClass": "SelectView",
          "prompt": "Select an Organisation",
          "label": "Podio Organisation",
          "required": true,
          "model": "organisations"
        }
      },
      "dynamicMetadata": true
    },
    "searchSpace": {
      "main": "./lib/actions/all/searchSpace.js",
      "title": "Search: Space (v1)",
      "description": "Search within a space (v1, bare array). See searchSpaceV2 for facet counts.",
      "fields": {
        "orgId": {
          "viewClass": "SelectView",
          "prompt": "Select an Organisation",
          "label": "Podio Organisation",
          "required": true,
          "model": "organisations"
        },
        "spaceId": {
          "viewClass": "SelectView",
          "prompt": "Select a Space",
          "label": "Podio Space",
          "required": true,
          "model": "spaces"
        }
      },
      "dynamicMetadata": true
    },
    "searchSpaceV2": {
